<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.desktopwindows.ChatsController"
            style="-fx-background-color: #F5F0EB;"
            stylesheets="@app.css">

    <top>
        <HBox style="-fx-background-color: #FAA030; -fx-padding: 18 16;" alignment="CENTER">
            <Label text="Task" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #3D1A00;"/>
            <Label text="Pilot" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <VBox style="-fx-background-color: #F5F0EB;">

            <HBox style="-fx-padding: 10 16 0 16; -fx-spacing: 24;
                         -fx-border-color: #CCCCCC; -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT">
                <Button fx:id="tabAll" text="Все" onAction="#onTabAll"
                        style="-fx-background-color: transparent; -fx-font-size: 14;
                               -fx-text-fill: #FAA030; -fx-font-weight: bold;
                               -fx-border-color: #FAA030; -fx-border-width: 0 0 2 0;"/>
                <Button fx:id="tabPr" text="ЛС" onAction="#onTabDm"
                        style="-fx-background-color: transparent; -fx-font-size: 14; -fx-text-fill: #555;"/>
                <Button fx:id="tabGroups" text="Группы" onAction="#onTabGroups"
                        style="-fx-background-color: transparent; -fx-font-size: 14; -fx-text-fill: #555;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="＋ Новый чат" onAction="#onAddChatClick"
                        style="-fx-background-color: #FAA030; -fx-text-fill: white;
                               -fx-background-radius: 20; -fx-font-size: 13;
                               -fx-padding: 5 14; -fx-cursor: hand;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox fx:id="chatListBox" style="-fx-padding: 8; -fx-spacing: 6;"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
