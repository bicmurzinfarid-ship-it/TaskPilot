<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.desktopwindows.LoginController"
           style="-fx-background-color: #F5F0EB;"
           stylesheets="@app.css">

    <VBox alignment="CENTER" spacing="0" maxWidth="380" minWidth="340"
          style="-fx-background-color: white; -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 24, 0, 0, 4);
                 -fx-padding: 44 40 36 40;">

        <ImageView fx:id="logoIcon" fitWidth="72" fitHeight="72" preserveRatio="true">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </ImageView>

        <HBox alignment="CENTER" spacing="0">
            <Label text="Task" style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #2D2D2D;"/>
            <Label text="Pilot" style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #FF9A2E;"/>
        </HBox>
        <Label text="Добро пожаловать!" style="-fx-font-size: 13; -fx-text-fill: #999;">
            <VBox.margin><Insets top="4" bottom="32"/></VBox.margin>
        </Label>

        <Label text="Логин" style="-fx-font-size: 12; -fx-text-fill: #555; -fx-font-weight: bold;">
            <VBox.margin><Insets bottom="5"/></VBox.margin>
        </Label>
        <TextField fx:id="usernameField" promptText="Введите ваш логин" styleClass="auth-field">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </TextField>

        <Label text="Пароль" style="-fx-font-size: 12; -fx-text-fill: #555; -fx-font-weight: bold;">
            <VBox.margin><Insets bottom="5"/></VBox.margin>
        </Label>
        <PasswordField fx:id="passwordField" promptText="Введите ваш пароль" styleClass="auth-field">
            <VBox.margin><Insets bottom="8"/></VBox.margin>
        </PasswordField>

        <Label fx:id="errorLabel" text="" wrapText="true" style="-fx-text-fill: #E53935; -fx-font-size: 12;">
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </Label>
        <Label fx:id="successLabel" text="" wrapText="true" style="-fx-text-fill: #43A047; -fx-font-size: 12;">
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </Label>

        <Button text="ВОЙТИ" onAction="#onLoginClick" maxWidth="Infinity" styleClass="auth-btn">
            <VBox.margin><Insets top="4" bottom="20"/></VBox.margin>
        </Button>

        <HBox alignment="CENTER" spacing="4">
            <Label text="Нет аккаунта?" style="-fx-font-size: 13; -fx-text-fill: #999;"/>
            <Button text="Зарегистрироваться" onAction="#onRegisterClick"
                    style="-fx-background-color: transparent; -fx-text-fill: #FF9A2E;
                           -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-padding: 0; -fx-border-color: transparent;"/>
        </HBox>
    </VBox>
</StackPane>
