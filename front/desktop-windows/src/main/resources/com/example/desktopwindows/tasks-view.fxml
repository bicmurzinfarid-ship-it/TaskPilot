<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane fx:id="rootPane" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.desktopwindows.TasksController"
            style="-fx-background-color: #F5F0EB;"
            stylesheets="@app.css">

    <top>
        <HBox style="-fx-background-color: #FAA030; -fx-padding: 18 16;" alignment="CENTER" spacing="10">
            <Label text="Task" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #3D1A00;"/>
            <Label text="Pilot" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="＋" onAction="#onAddTaskClick"
                    style="-fx-background-color: transparent; -fx-border-color: white;
                           -fx-border-radius: 50; -fx-background-radius: 50;
                           -fx-font-size: 16; -fx-padding: 2 8; -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox style="-fx-background-color: #F5F0EB;">

            <HBox style="-fx-padding: 8 16 0 16; -fx-spacing: 20; -fx-border-color: #CCCCCC; -fx-border-width: 0 0 1 0;">
                <Button fx:id="tabRecent" text="Последние" onAction="#onTabRecent"
                        style="-fx-background-color: transparent; -fx-font-size: 14;
                               -fx-text-fill: #FAA030; -fx-font-weight: bold; -fx-border-color: #FAA030; -fx-border-width: 0 0 2 0;"/>
                <Button fx:id="tabAssignedToMe" text="Порученные мне" onAction="#onTabAssignedToMe"
                        style="-fx-background-color: transparent; -fx-font-size: 14; -fx-text-fill: #555;"/>
                <Button fx:id="tabAssignedByMe" text="Порученные другим" onAction="#onTabAssignedByMe"
                        style="-fx-background-color: transparent; -fx-font-size: 14; -fx-text-fill: #555;"/>
            </HBox>

            <ScrollPane fx:id="taskScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox fx:id="taskListBox" style="-fx-padding: 12; -fx-spacing: 10;"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
