<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.desktopwindows.ChatsController"
            style="-fx-background-color: #F5F0EB;">

    <top>
        <HBox style="-fx-background-color: #FAA757; -fx-padding: 10;" alignment="CENTER" spacing="10">
            <Label text="Чаты" style="-fx-font-size: 18; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
            <TextField promptText="Поиск..." prefWidth="250"
                       style="-fx-background-radius: 15; -fx-padding: 5 10;"/>
        </HBox>
    </top>

    <left>
        <VBox style="-fx-background-color: #FAA757; -fx-padding: 10; -fx-spacing: 15; -fx-min-width: 100;" alignment="TOP_CENTER">
            <Button text="Главная" onAction="#onNavHome"
                    style="-fx-background-color: transparent; -fx-font-size: 13; -fx-text-fill: #3D1A00;"/>
            <Button text="Календарь" onAction="#onNavCalendar"
                    style="-fx-background-color: transparent; -fx-font-size: 13; -fx-text-fill: #3D1A00;"/>
            <Button text="Чаты"
                    style="-fx-background-color: transparent; -fx-font-size: 13; -fx-text-fill: #3D1A00; -fx-font-weight: bold;"/>
            <Button text="Настройки"
                    style="-fx-background-color: transparent; -fx-font-size: 13; -fx-text-fill: #3D1A00;"/>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #F5F0EB;">

            <!-- Вкладки Все / ЛС / Группы -->
            <HBox style="-fx-padding: 8 16 0 16; -fx-spacing: 24;
                         -fx-border-color: #CCCCCC; -fx-border-width: 0 0 1 0;">
                <Button fx:id="tabAll" text="Все" onAction="#onTabAll"
                        style="-fx-background-color: transparent; -fx-font-size: 14;
                               -fx-text-fill: #FAA757; -fx-font-weight: bold;
                               -fx-border-color: #FAA757; -fx-border-width: 0 0 2 0;"/>
                <Button fx:id="tabDm" text="ЛС" onAction="#onTabDm"
                        style="-fx-background-color: transparent; -fx-font-size: 14; -fx-text-fill: #555;"/>
                <Button fx:id="tabGroups" text="Группы" onAction="#onTabGroups"
                        style="-fx-background-color: transparent; -fx-font-size: 14; -fx-text-fill: #555;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox fx:id="chatListBox" style="-fx-padding: 0;"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
