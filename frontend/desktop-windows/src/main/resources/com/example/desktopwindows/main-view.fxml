<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.desktopwindows.MainController"
            style="-fx-background-color: #F5F0EB;">

    <!-- Верхняя панель -->
    <top>
        <HBox style="-fx-background-color: #FAA757; -fx-padding: 10;" alignment="CENTER" spacing="10">
            <Label text="Главная" style="-fx-font-size: 18; -fx-font-weight: bold;" HBox.hgrow="NEVER"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField promptText="Поиск..." prefWidth="300"
                       style="-fx-background-radius: 15; -fx-padding: 5 10;"/>
        </HBox>
    </top>

    <!-- Левая панель навигации -->
    <left>
        <VBox style="-fx-background-color: #FAA757; -fx-padding: 10; -fx-spacing: 15; -fx-min-width: 100;" alignment="TOP_CENTER">
            <Button text="Главная" onAction="#onNavHome"
                    style="-fx-background-color: transparent; -fx-font-size: 13; -fx-text-fill: #3D1A00; -fx-font-weight: bold;"/>
            <Button text="Календарь" onAction="#onNavCalendar"
                    style="-fx-background-color: transparent; -fx-font-size: 13; -fx-text-fill: #3D1A00;"/>
            <Button text="Чаты" onAction="#onNavChats"
                    style="-fx-background-color: transparent; -fx-font-size: 13; -fx-text-fill: #3D1A00;"/>
            <Button text="Настройки" onAction="#onNavSettings"
                    style="-fx-background-color: transparent; -fx-font-size: 13; -fx-text-fill: #3D1A00;"/>
        </VBox>
    </left>

    <!-- Центральная область -->
    <center>
        <VBox style="-fx-background-color: #F5F0EB;">

            <!-- Задачи -->
            <HBox style="-fx-padding: 12 16; -fx-border-color: #CCCCCC; -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT" onMouseClicked="#onTasksSectionClick">
                <Label text="Задачи" style="-fx-font-size: 16;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="▶" onAction="#onTasksSectionClick"
                        style="-fx-background-color: transparent; -fx-font-size: 14;"/>
            </HBox>

            <!-- Группы -->
            <HBox style="-fx-padding: 12 16; -fx-border-color: #CCCCCC; -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT">
                <Label text="Группы" style="-fx-font-size: 16;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="▶" style="-fx-background-color: transparent; -fx-font-size: 14;"/>
            </HBox>

            <!-- Проекты -->
            <HBox style="-fx-padding: 12 16 6 16;" alignment="CENTER_LEFT">
                <Label text="📁 Проекты" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="＋" onAction="#onAddProjectClick"
                        style="-fx-background-color: transparent; -fx-border-color: #888; -fx-border-radius: 50; -fx-background-radius: 50; -fx-font-size: 16; -fx-padding: 2 8;"/>
            </HBox>

            <ListView fx:id="projectListView" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0 8;"/>

        </VBox>
    </center>

    <!-- Контекстное меню проекта (правый клик) будет из кода -->

</BorderPane>
